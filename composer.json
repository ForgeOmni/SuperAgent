{
    "name": "forgeomni/superagent",
    "description": "Multi-provider AI Agent SDK for Laravel 10+. Run the full agentic loop in-process with tool use support.",
    "keywords": ["laravel", "agent", "ai", "anthropic", "llm", "tool-use"],
    "license": "MIT",
    "type": "library",
    "require": {
        "php": "^8.1",
        "illuminate/support": "^10.0|^11.0|^12.0",
        "guzzlehttp/guzzle": "^7.0"
    },
    "require-dev": {
        "orchestra/testbench": "^8.0|^9.0|^10.0",
        "phpunit/phpunit": "^10.0|^11.0"
    },
    "autoload": {
        "psr-4": {
            "SuperAgent\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "SuperAgent\\Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "SuperAgent\\SuperAgentServiceProvider"
            ],
            "aliases": {
                "SuperAgent": "SuperAgent\\Facades\\SuperAgent"
            }
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
